# Agus OSINT Backend - Environment Variables
# Copy this to .env and fill in your API keys

# ACLED conflict data (https://acleddata.com/ - free registration)
# Required for: conflicts, terrorism layers (OAuth flow)
ACLED_EMAIL=
ACLED_PASSWORD=

# AbuseIPDB (https://www.abuseipdb.com/ - free tier)
# Optional: enhances cyber threat layer with geolocated IPs
ABUSEIPDB_API_KEY=

# Windy Webcams (https://api.windy.com/ - free tier)
# Optional: enables live CCTV/webcam layer
WINDY_API_KEY=

# OpenAIP (https://www.openaip.net/ - free registration)
# Optional: enables airspace restrictions layer
OPENAIP_API_KEY=
